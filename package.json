{
  "name": "calm-screen",
  "version": "1.0.0",
  "description": "Calm Screen - Chrome extension for visual sensitivity (blue light cut, desaturate, animation mute, dark mode force)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && node scripts/package-zip.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/node": "^25.8.0",
    "@vitest/ui": "^1.6.1",
    "jsdom": "^24.1.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.1"
  }
}
